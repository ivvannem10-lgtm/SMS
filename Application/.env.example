# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings

# Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"

# Publishable key (Settings → API → Publishable key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Pooled connection — used by Prisma at runtime (Settings → Database → Transaction, port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — used by Prisma for migrations only (Settings → Database → Direct, port 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Service role key — server-side only, never expose to browser (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
